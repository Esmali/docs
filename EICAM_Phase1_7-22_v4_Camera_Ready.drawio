        <mxCell id="blue-panel-t4" value="The scripts generate the Submission Quality-Control Anomaly Report. When anomalies exist, the engineer returns the findings to the same Customer Success Manager for correction and follow-up." style="fontFamily=Helvetica;text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
